APP_NAME=DataNarasi
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Makassar

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (Catatan: DATABASE_URL akan diset otomatis oleh Railway)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=data_narasi
DB_USERNAME=root
DB_PASSWORD=

# Queue (wajib Redis untuk job processing)
QUEUE_CONNECTION=redis

# Redis (Catatan: REDIS_URL akan diset otomatis oleh Railway)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Python Microservice
PYTHON_SERVICE_URL=http://localhost:8001
PYTHON_SERVICE_SECRET=rahasia-internal-token-ganti-ini
PYTHON_SERVICE_TIMEOUT=10
ALLOWED_ORIGINS=http://localhost:8000

# Storage
FILESYSTEM_DISK=local
MAX_UPLOAD_SIZE_MB=10

# ============================================
# AI PROVIDERS — isi key yang kamu punya
# Kosongkan yang belum ada, sistem akan skip
# ============================================

# Prioritas 1: Gemini Free (Google)
# Daftar di: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Prioritas 2: Kimi API (Moonshot AI)
# Daftar di: https://platform.moonshot.cn/
KIMI_API_KEY=

# Prioritas 3: GLM (Zhipu AI)
# Daftar di: https://open.bigmodel.cn/
GLM_API_KEY=

# Prioritas 4: NVIDIA NIM (Free, 40 RPM)
# Daftar di: https://build.nvidia.com/ → Generate API Key
# Model default: meta/llama-3.1-8b-instruct
# Docs: https://docs.api.nvidia.com/nim/reference/
NVIDIA_API_KEY=

# Prioritas 5: MiniMax (OpenAI Compatible)
# Daftar di: https://platform.minimax.io/
# Model default: MiniMax-M2.5
# API key prefix: sk-cp- (Coding Plan) atau sk-api- (Standard)
MINIMAX_API_KEY=

# Prioritas 6: Claude (Anthropic) — aktifkan saat sudah subscribe
# Daftar di: https://console.anthropic.com/
CLAUDE_API_KEY=

# Prioritas 7: OpenRouter (300+ models via unified API)
# Daftar di: https://openrouter.ai/settings/keys
# Model default: google/gemini-2.5-flash (Free)
# Lihat semua model: https://openrouter.ai/models
OPENROUTER_API_KEY=

# Urutan fallback — ubah di sini tanpa edit kode
# Provider yang API key-nya kosong akan di-skip otomatis
AI_PROVIDER_ORDER=gemini,kimi,glm,nvidia,minimax,claude,openrouter

# Timeout per AI request (detik)
AI_REQUEST_TIMEOUT=30

# Mail (opsional untuk notifikasi)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@datanarasai.app
MAIL_FROM_NAME="${APP_NAME}"
